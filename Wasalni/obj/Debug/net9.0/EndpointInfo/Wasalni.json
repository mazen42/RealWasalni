  "components": {
    "schemas": {
      "DriverApprovalStatus": {
        "enum": [
          "pending",
          "approved",
          "rejected",
          "suspended"
        ],
        "type": "string"
      },
      "DriverTripRequestDTO": {
        "required": [
          "fromLocation",
          "toLocation"
        ],
        "type": "object",
        "properties": {
          "startTime": {
            "type": "string",
            "format": "time"
          },
          "endTime": {
            "type": "string",
            "format": "time"
          },
          "fromLocation": {
            "$ref": "#/components/schemas/LocationDTO"
          },
          "toLocation": {
            "$ref": "#/components/schemas/LocationDTO"
          }
        },
        "additionalProperties": false
      },
      "Gender": {
        "enum": [
          "male",
          "female"
        ],
        "type": "string"
      },
      "LocationDTO": {
        "type": "object",
        "properties": {
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "LoginDTO": {
        "required": [
          "email",
          "password",
          "rememberMe"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          },
          "rememberMe": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "TicketValidationDTO": {
        "required": [
          "ticketNumber",
          "tripId"
        ],
        "type": "object",
        "properties": {
          "ticketNumber": {
            "minLength": 1,
            "type": "string"
          },
          "tripId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "TripBookDTO": {
        "type": "object",
        "properties": {
          "fromGovernerate": {
            "type": "string",
            "nullable": true
          },
          "toGovernerate": {
            "type": "string",
            "nullable": true
          },
          "charIndex": {
            "type": "integer",
            "format": "int32"
          },
          "fromLocation": {
            "$ref": "#/components/schemas/LocationDTO"
          },
          "toLocation": {
            "$ref": "#/components/schemas/LocationDTO"
          },
          "tripId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "arrivalTime": {
            "type": "string",
            "format": "time"
          },
          "vehicleType": {
            "$ref": "#/components/schemas/VehicleType"
          },
          "tripType": {
            "$ref": "#/components/schemas/TripType"
          }
        },
        "additionalProperties": false
      },
      "TripRequestDTO": {
        "type": "object",
        "properties": {
          "arrivalTime": {
            "type": "string",
            "format": "time"
          },
          "fromLocation": {
            "$ref": "#/components/schemas/LocationDTO"
          },
          "toLocation": {
            "$ref": "#/components/schemas/LocationDTO"
          },
          "vehicleType": {
            "$ref": "#/components/schemas/VehicleType"
          },
          "tripType": {
            "$ref": "#/components/schemas/TripType"
          }
        },
        "additionalProperties": false
      },
      "TripType": {
        "enum": [
          "single",
          "monthly"
        ],
        "type": "string"
      },
      "UpdateDriverStatusAndDataDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "driverApprovalStatus": {
            "$ref": "#/components/schemas/DriverApprovalStatus"
          }
        },
        "additionalProperties": false
      },
      "UserType": {
        "enum": [
          "passenger",
          "driver",
          "admin"
        ],
        "type": "string"
      },
      "VehicleType": {
        "enum": [
          "bus",
          "miniBus",
          "taxi"
        ],
        "type": "string"
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "Enter 'Bearer' [space] and then your valid token.",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
