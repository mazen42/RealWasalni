  "paths": {
    "/api/AccountUser/Register": {
      "post": {
        "tags": [
          "AccountUser"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "Age",
                  "Email",
                  "Gender",
                  "Name",
                  "Password",
                  "PhoneNumber",
                  "UserType"
                ],
                "type": "object",
                "properties": {
                  "Email": {
                    "type": "string",
                    "format": "email"
                  },
                  "Password": {
                    "type": "string"
                  },
                  "Name": {
                    "type": "string"
                  },
                  "PhoneNumber": {
                    "type": "string"
                  },
                  "HomeLocation.Longitude": {
                    "type": "number",
                    "format": "double"
                  },
                  "HomeLocation.Latitude": {
                    "type": "number",
                    "format": "double"
                  },
                  "Gender": {
                    "$ref": "#/components/schemas/Gender"
                  },
                  "UserType": {
                    "$ref": "#/components/schemas/UserType"
                  },
                  "Age": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "LicenseImageFace": {
                    "type": "string",
                    "format": "binary"
                  },
                  "IdCardFace": {
                    "type": "string",
                    "format": "binary"
                  },
                  "LicenseImageBack": {
                    "type": "string",
                    "format": "binary"
                  },
                  "IdCardBack": {
                    "type": "string",
                    "format": "binary"
                  },
                  "VehicleType": {
                    "$ref": "#/components/schemas/VehicleType"
                  },
                  "PlateNumber": {
                    "type": "string"
                  }
                }
              },
              "encoding": {
                "Email": {
                  "style": "form"
                },
                "Password": {
                  "style": "form"
                },
                "Name": {
                  "style": "form"
                },
                "PhoneNumber": {
                  "style": "form"
                },
                "HomeLocation.Longitude": {
                  "style": "form"
                },
                "HomeLocation.Latitude": {
                  "style": "form"
                },
                "Gender": {
                  "style": "form"
                },
                "UserType": {
                  "style": "form"
                },
                "Age": {
                  "style": "form"
                },
                "LicenseImageFace": {
                  "style": "form"
                },
                "IdCardFace": {
                  "style": "form"
                },
                "LicenseImageBack": {
                  "style": "form"
                },
                "IdCardBack": {
                  "style": "form"
                },
                "VehicleType": {
                  "style": "form"
                },
                "PlateNumber": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
